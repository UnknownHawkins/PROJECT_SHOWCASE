# ─── Site Settings ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CONTACT_ALLOWED_ORIGIN=http://localhost:3000
# Discord or Slack Webhook to receive contact submissions (Optional)
CONTACT_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase or Neon PostgreSQL database URL (Required for database operations)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/portfolio?schema=public"

# ─── Redis Cache ──────────────────────────────────────────────────────────────
# Upstash Redis REST credentials (used by src/lib/cache.ts for GitHub stats caching)
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── GitHub Integration ────────────────────────────────────────────────────────
# Your GitHub username (defaults to "UnknownHawkins" if not set)
GITHUB_USERNAME=UnknownHawkins
# Personal Access Token (PAT) for GitHub GraphQL and REST API (Optional, falls back to REST/mock)
GITHUB_TOKEN=ghp_...

# ─── Clerk Authentication ──────────────────────────────────────────────────────
# Clerk Publishable and Secret Keys (Optional)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── AI Playground ────────────────────────────────────────────────────────────
# Gemini API Key for AI resume parsing, chat, and skill analyzer (Optional)
GEMINI_API_KEY=...
# OpenAI API Key (Optional)
OPENAI_API_KEY=sk-proj-...
